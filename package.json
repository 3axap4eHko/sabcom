{
  "name": "sabcom",
  "version": "0.1.141",
  "description": "A TypeScript/Node.js library for inter-thread communication using SharedArrayBuffer with atomic operations for raw buffer data transfer",
  "type": "module",
  "types": "build/index.d.ts",
  "main": "build/index.cjs",
  "module": "build/index.js",
  "exports": {
    "require": "./build/index.cjs",
    "import": "./build/index.js"
  },
  "files": [
    "build",
    "src/index.ts"
  ],
  "scripts": {
    "build": "rm -rf build && inop src build -i __tests__ -i __bench__ -i *.tmp.ts && tsc --declaration --emitDeclarationOnly",
    "lint": "eslint src",
    "test": "vitest run",
    "bench": "pnpm build && overtake src/__bench__/* --pin-cores -w 1 --progress",
    "bench:test": "pnpm bench --compare-baseline .bench-baseline.json",
    "bench:save": "pnpm bench --save-baseline .bench-baseline.json",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3axap4eHko/sabcom.git"
  },
  "keywords": [
    "SharedArrayBuffer",
    "shared",
    "atomic",
    "buffer",
    "thread",
    "worker",
    "communication",
    "concurrency",
    "parallel",
    "multithreading",
    "ipc",
    "inter-process",
    "synchronization",
    "memory"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Ivan Zakharchanka",
    "email": "3axap4eHko@gmail.com",
    "url": "https://linkedin.com/in/3axap4eHko"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "inop": "^0.9.0",
    "overtake": "^2.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
